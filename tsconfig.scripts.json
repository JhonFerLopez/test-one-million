{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "target": "ES2023",
    "baseUrl": "./",
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  }
}
